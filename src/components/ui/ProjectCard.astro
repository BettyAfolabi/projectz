---
import type { CollectionEntry } from 'astro:content';

interface Props {
  project: CollectionEntry<'projects'>;
}

const { project } = Astro.props;
const { title, description, featured, tags = [], coverImage, videoSrc } = project.data;

const colSpan = featured
  ? 'col-span-12 md:col-span-8'
  : 'col-span-12 md:col-span-4';

const transitionName = `project-${project.slug}`;
---

<a
  href={`/projects/${project.slug}`}
  data-tags={JSON.stringify(tags)}
  class={`project-card group flex flex-col overflow-hidden rounded-2xl transition-all duration-300 ${colSpan}`}
  style={`view-transition-name: ${transitionName}; border: 1px solid var(--theme-border); background: var(--theme-surface);`}
>
  <!-- Image — smaller, 4:3 ratio feels more like a card thumbnail -->
  <div class="relative w-full overflow-hidden" style="aspect-ratio: 4/3; background: color-mix(in srgb, var(--theme-accent) 6%, var(--theme-surface));">
    {videoSrc && (
      <video
        class="card-video absolute inset-0 w-full h-full object-cover opacity-0 transition-opacity duration-500"
        src={videoSrc} muted loop playsinline preload="none"
      />
    )}
    {coverImage ? (
      <img
        src={coverImage}
        alt={title}
        class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-[1.03]"
      />
    ) : (
      <div class="w-full h-full flex items-center justify-center">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none"
          style="color: var(--theme-accent); opacity: 0.25;">
          <rect x="3" y="3" width="18" height="18" rx="3" stroke="currentColor" stroke-width="1.5"/>
          <path d="M3 15l5-5 4 4 3-3 6 6" stroke="currentColor" stroke-width="1.5"
            stroke-linecap="round" stroke-linejoin="round"/>
          <circle cx="8.5" cy="8.5" r="1.5" fill="currentColor"/>
        </svg>
      </div>
    )}

    {featured && (
      <span class="absolute top-3 left-3 text-[10px] font-mono font-semibold uppercase tracking-widest px-2 py-0.5 rounded-full"
        style="background: var(--theme-accent); color: #fff;">
        Featured
      </span>
    )}
  </div>

  <!-- Text below image -->
  <div class="flex flex-col gap-2.5 p-4">
    {tags.length > 0 && (
      <div class="flex flex-wrap gap-1.5">
        {tags.slice(0, 3).map((tag) => (
          <span
            class="tag-pill text-[10px] font-mono px-2 py-0.5 rounded-full cursor-pointer transition-colors"
            data-tag={tag}
            style="border: 1px solid var(--theme-border); color: var(--theme-muted);"
          >{tag}</span>
        ))}
        {tags.length > 3 && (
          <span class="text-[10px] font-mono" style="color: var(--theme-muted); opacity: 0.4;">+{tags.length - 3}</span>
        )}
      </div>
    )}

    <h2 class="text-sm font-semibold tracking-tight leading-snug"
      style="color: var(--theme-text);">{title}</h2>
    <p class="text-xs leading-relaxed line-clamp-2"
      style="color: var(--theme-muted);">{description}</p>

    <span class="text-[11px] font-mono mt-1 opacity-0 group-hover:opacity-100 transition-opacity"
      style="color: var(--theme-accent);">View project →</span>
  </div>
</a>

<script>
  document.querySelectorAll<HTMLAnchorElement>('.project-card').forEach((card) => {
    const video = card.querySelector<HTMLVideoElement>('.card-video');

    if (video) {
      card.addEventListener('mouseenter', () => { video.play(); video.style.opacity = '0.9'; });
      card.addEventListener('mouseleave', () => { video.pause(); video.currentTime = 0; video.style.opacity = '0'; });
    }

    card.addEventListener('mouseenter', () => {
      card.style.borderColor = getComputedStyle(document.documentElement).getPropertyValue('--theme-accent').trim();
    });
    card.addEventListener('mouseleave', () => {
      card.style.borderColor = 'var(--theme-border)';
    });

    card.querySelectorAll<HTMLElement>('.tag-pill').forEach((pill) => {
      pill.addEventListener('click', (e) => {
        e.preventDefault();
        e.stopPropagation();
        const tag = pill.dataset.tag!;
        const url = new URL(window.location.href);
        url.searchParams.set('tag', tag);
        window.history.pushState({}, '', url);
        document.dispatchEvent(new CustomEvent('tag-filter', { detail: tag }));
      });
      pill.addEventListener('mouseenter', () => {
        const a = getComputedStyle(document.documentElement).getPropertyValue('--theme-accent').trim();
        pill.style.borderColor = a;
        pill.style.color = a;
      });
      pill.addEventListener('mouseleave', () => {
        pill.style.borderColor = 'var(--theme-border)';
        pill.style.color = 'var(--theme-muted)';
      });
    });
  });
</script>