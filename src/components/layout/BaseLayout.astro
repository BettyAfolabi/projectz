---
import '../../styles/global.css';
import CommandPalette from '../islands/CommandPalette';
import AvailabilityIsland from '../islands/AvailabilityIsland.astro';
import ThemeSwitcher from '../islands/ThemeSwitcher.astro';
import { getCollection } from 'astro:content';
import { THEMES_MAP, DEFAULT_THEME_ID } from '../../lib/themes';
import ThemeTooltip from '../islands/ThemeTooltip.astro';
import { getMediumPosts } from '../../lib/medium';
import { buildCommands } from '../../data/commands';
 
const themesJson = JSON.stringify(THEMES_MAP);
const defaultTheme = DEFAULT_THEME_ID;

const projects = await getCollection('projects');
const posts = await getMediumPosts(10).catch(() => []);
const commands = buildCommands(projects, posts);
---


<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="Frontend Engineer — building fast, accessible, obsessively detailed interfaces." />
    <title>Elizabeth — Frontend Engineer</title>
    <link rel="icon" href="/favicon.ico" />

    <!-- Apply saved theme before first paint -->
    <script is:inline define:vars={{ themesJson, defaultTheme }}>
      (function () {
        const themes = JSON.parse(themesJson);
        const saved = localStorage.getItem('portfolio-theme') || defaultTheme;
        const t = themes[saved] || themes[defaultTheme];
        const r = document.documentElement;
        r.setAttribute('data-theme', saved);
        r.style.setProperty('--theme-bg',           t.bg);
        r.style.setProperty('--theme-surface',      t.surface);
        r.style.setProperty('--theme-border',       t.border);
        r.style.setProperty('--theme-accent',       t.accent);
        r.style.setProperty('--theme-accent-hover', t.accentHover);
        r.style.setProperty('--theme-text',         t.text);
        r.style.setProperty('--theme-muted',        t.muted);
        r.style.setProperty('--theme-nav-text',     t.navText);
        r.style.setProperty('--theme-glow',         t.glow);
        r.style.setProperty('--theme-accent-text', t.accentText);
        document.body && (document.body.style.backgroundColor = t.bg);
      })();
    </script>
  </head>

  <body class="min-h-screen antialiased" style="background-color:var(--theme-bg);color:var(--theme-text);">

    <!-- Background -->
    <div class="fixed inset-0 -z-10 pointer-events-none">
      <div class="theme-glow absolute inset-0" />
      <svg class="absolute inset-0 w-full h-full opacity-[0.04]" xmlns="http://www.w3.org/2000/svg">
        <filter id="grain">
          <feTurbulence type="fractalNoise" baseFrequency="0.65" numOctaves="3" stitchTiles="stitch" />
          <feColorMatrix type="saturate" values="0" />
        </filter>
        <rect width="100%" height="100%" filter="url(#grain)" />
      </svg>
      <div class="absolute inset-0 opacity-[0.03]"
        style="background-image:radial-gradient(circle,var(--theme-text) 1px,transparent 1px);background-size:32px 32px;" />
    </div>

    <!-- Nav -->
    <nav class="fixed top-0 left-0 right-0 z-30 flex items-center justify-between px-6 py-4 backdrop-blur-sm"
      style="border-bottom:0.5px solid var(--theme-border);">
      <a href="/" class="text-sm font-mono font-semibold" style="color:var(--theme-nav-text);">
        EA<span style="color:var(--theme-accent);">.</span>
      </a>
      <div class="flex items-center gap-1">
        <div class="hidden md:flex items-center gap-1">
          {[
            { href:'/#experience',    label:'Work'    },
            { href:'/blog',    label:'Blog'    },
            { href:'/#stack',   label:'Stack'   },
            { href:'/#contact', label:'Contact' },
          ].map(({ href, label }) => (
            <a href={href} class="nav-anchor px-3 py-1.5 rounded-lg text-sm font-medium transition-all duration-150"
              style="color:var(--theme-nav-text);">{label}</a>
          ))}
        </div>
        <button
          class="hidden md:flex items-center gap-1.5 px-2.5 py-1 rounded-lg text-xs font-mono ml-2 transition-all cursor-pointer"
          style="border:0.5px solid var(--theme-border);color:var(--theme-nav-text);"
          onclick="window.dispatchEvent(new KeyboardEvent('keydown',{key:'k',metaKey:true,bubbles:true}))">
          ⌘K
        </button>
        <button id="mobile-menu-btn" class="md:hidden p-1 ml-1" style="color:var(--theme-nav-text);" aria-label="Open menu">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
            <path d="M3 6h14M3 10h14M3 14h14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
        </button>
      </div>
    </nav>

    <!-- Mobile drawer -->
    <div id="mobile-menu"
      class="fixed inset-0 z-40 backdrop-blur-md flex flex-col items-center justify-center gap-8 translate-x-full transition-transform duration-300 ease-in-out"
      style="background:color-mix(in srgb,var(--theme-bg) 96%,transparent);">
      <button id="mobile-menu-close" class="absolute top-5 right-6 text-2xl" style="color:var(--theme-nav-text);">✕</button>
      {[
        { href:'/',         label:'Home'    },
        { href:'/#experience', label:'Work' },
        { href:'/blog',    label:'Blog'    },
        { href:'/#stack',   label:'Stack'   },
        { href:'/#contact', label:'Contact' },
      ].map(({ href, label }) => (
        <a href={href} class="drawer-link text-3xl tracking-tighter hover:underline"
          style="color:var(--theme-text);">{label}</a>
      ))}
      <a href="mailto:betty4web@gmail.com" class="mt-2 px-6 py-3 rounded-full text-sm font-semibold"
        style="background:var(--theme-accent);color:#fff;">
        Get in touch
      </a>
    </div>

    <div class="pt-16">
      <slot />
    </div>

    <AvailabilityIsland />
    <ThemeSwitcher />
    <ThemeTooltip />
    <CommandPalette client:load items={commands} />
  </body>
</html>

<script type="module">
  import { initUI } from '../../lib/ui';
  initUI();
</script>
<script is:inline>
  const revealObserver = new IntersectionObserver(
    (entries) => {
      for (const entry of entries) {
        if (!entry.isIntersecting) continue;

        const el = entry.target;
        el.classList.add('is-visible');
        revealObserver.unobserve(el);
      }
    },
    {
      threshold: 0.12,
      rootMargin: '0px 0px -10% 0px'
    }
  );

  function initReveal() {
    document.querySelectorAll('.reveal-section, .reveal-item')
      .forEach((el, i) => {
        el.style.setProperty('--r-index', String(i));
        revealObserver.observe(el);
      });
  }

  document.addEventListener('DOMContentLoaded', initReveal);
</script>