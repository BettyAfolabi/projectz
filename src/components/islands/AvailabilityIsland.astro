---
const available = true;
---

<div
  id="avail-island"
  class="fixed bottom-6 left-1/2 -translate-x-1/2 z-40 flex items-center gap-2 px-4 py-2 rounded-full text-sm font-medium shadow-lg backdrop-blur-md pointer-events-none select-none"
  style={available
    ? 'border: 1px solid rgba(52,211,153,0.3); background: rgba(6,78,59,0.8); color: rgb(110,231,183);'
    : 'border: 1px solid var(--theme-border); background: color-mix(in srgb, var(--theme-bg) 80%, transparent); color: var(--theme-muted);'
  }
>
  <span class={`w-2 h-2 rounded-full ${available ? 'bg-emerald-400 animate-pulse' : 'bg-current opacity-40'}`} />
  {available ? 'Available for work' : 'Currently unavailable'}
</div>