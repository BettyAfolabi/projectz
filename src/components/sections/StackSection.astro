---
// Stack.astro
const stack = {
  Core: ['TypeScript', 'React', 'Next.js', 'Tailwind'],
  Ecosystem: ['Firebase', 'Zustand', 'REST APIs', 'Git', 'Vercel', 'GitHub', 'Jira'],
  Exploring: ['AI APIs', 'Astro', 'Web3', 'Performance Optimization']
};
---

<section
  id="stack"
  class="mx-auto max-w-7xl px-6 pb-24 pt-16 scroll-mt-20 reveal-section"
  style="border-top:1px solid var(--theme-border);"
>

  <!-- Header -->
  <div class="mb-14 reveal-item">
    <p class="text-xs font-mono tracking-[0.2em] uppercase mb-3"
      style="color:var(--theme-accent);opacity:0.8;">
      Stack
    </p>
    <h2 class="text-3xl sm:text-4xl font-bold tracking-tight"
      style="color:var(--theme-text);">
      Tools I work with
    </h2>
  </div>

  <!-- 3 cards ONLY -->
  <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 reveal-item">

    {Object.entries(stack).map(([category, items]) => (
      <div
        class="rounded-2xl p-6 flex flex-col gap-4 transition-all"
        style="border:1px solid var(--theme-border); background:var(--theme-surface);"
      >

        <!-- Title -->
        <p class="text-xs font-mono uppercase tracking-[0.2em]"
          style="color:var(--theme-muted);opacity:0.6;">
          {category}
        </p>

        <!-- Clean list (NOT pills) -->
        <p class="text-sm leading-relaxed"
          style="color:var(--theme-text);">
          {items.join(' · ')}
        </p>

      </div>
    ))}

  </div>
</section>