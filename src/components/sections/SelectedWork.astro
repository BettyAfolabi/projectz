---
import ProjectCard from '../ui/ProjectCard.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  projects: CollectionEntry<'projects'>[];
}

const { projects } = Astro.props;

const sorted = [...projects]
  .sort((a, b) => Number(b.data.featured) - Number(a.data.featured))
  .slice(0, 4);
---

<section id="work" class="mx-auto max-w-7xl px-6 pb-24 scroll-mt-20 reveal-section">

  <div class="mb-10 reveal-item">
    <p class="text-[0.7rem] font-mono font-medium tracking-[0.15em] uppercase text-accent opacity-80 mb-2">
      PORTFOLIO
    </p>
    <div class="flex flex-col items-start justify-between gap-2 sm:flex-row sm:items-baseline">
      <h2 class="text-[clamp(1.5rem,3vw,2rem)] font-bold tracking-tight text-primary">
        Selected Work
      </h2>
      <!-- <a
        href="/projects"
        class="inline-flex items-center gap-1.5 text-[0.8rem] font-medium text-muted hover:text-accent transition-colors whitespace-nowrap"
      >
        All projects
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
          <path d="M2.5 11.5L11.5 2.5M11.5 2.5H5.5M11.5 2.5V8.5"
            stroke="currentColor" stroke-width="1.3"
            stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a> -->
    </div>
  </div>

  <!--
    12-col grid:
    - Featured card  → col-span-12 md:col-span-8  (set inside ProjectCard)
    - Secondary cards → col-span-12 md:col-span-4  (set inside ProjectCard)
  -->
  <div class="grid grid-cols-12 gap-4 auto-rows-[minmax(200px,auto)]">
    {sorted.map((project) => (
      <ProjectCard project={project} />
    ))}
  </div>

</section>