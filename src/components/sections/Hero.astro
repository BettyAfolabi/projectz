---
// Hero.astro
---

<section class="relative mx-auto max-w-7xl px-6 pt-24 md:pt-32 pb-20 md:pb-24 reveal-section">
  <div class="flex items-center gap-3 mb-6 md:mb-8 animate-fade-in reveal-item">
    <span class="h-px w-8 md:w-12" style="background: var(--theme-accent); opacity: 0.6;" />
    <span class="text-xs font-mono tracking-[0.2em] uppercase" style="color: var(--theme-accent); opacity: 0.8;">
      Frontend Engineer
    </span>
  </div>

  <h1
    class="reveal-item text-[clamp(2.8rem,10vw,8rem)] font-black leading-[0.9] tracking-tighter animate-slide-up"
    style="font-family: 'Georgia', serif; letter-spacing: -0.04em; color: var(--theme-text);"
  >
    Elizabeth<br />
    <span id="hero-gradient-name" style="
      background: linear-gradient(135deg, var(--theme-accent), var(--theme-accent-hover));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    ">
      Afolabi
    </span>
  </h1>

  <p
    class="mt-6 md:mt-8 max-w-xl text-base md:text-lg leading-relaxed animate-slide-up"
    style="animation-delay: 0.1s; font-family: 'Georgia', serif; color: var(--theme-muted);"
  >
    I build interfaces that feel inevitable — fast, accessible, and obsessively
    detailed. Currently available for freelance and full-time roles.
  </p>

  <div class="reveal-item mt-8 md:mt-10 flex flex-wrap items-center gap-3 animate-slide-up" style="animation-delay: 0.2s;">
    <a
      href="mailto:betty4web@gmail.com"
      class="group flex items-center gap-2 px-5 py-2.5 rounded-full text-white text-sm font-semibold transition-all duration-200"
      style="background: var(--theme-accent);"
      onmouseover="this.style.background='var(--theme-accent-hover)'"
      onmouseout="this.style.background='var(--theme-accent)'"
    >
      Get in touch
      <span class="group-hover:translate-x-0.5 transition-transform">→</span>
    </a>
    <a
      href="/cv.pdf"
      target="_blank"
      class="flex items-center gap-2 px-5 py-2.5 rounded-full text-sm font-medium transition-all duration-200"
      style="border: 1px solid var(--theme-border); color: var(--theme-muted);"
      onmouseover="this.style.borderColor='var(--theme-accent)'; this.style.color='var(--theme-text)'"
      onmouseout="this.style.borderColor='var(--theme-border)'; this.style.color='var(--theme-muted)'"
    >
      Download CV
    </a>
    <div class="flex items-center gap-4 ml-1">
      <a href="https://github.com/BettyAfolabi" target="_blank"
        class="text-sm font-mono transition-colors"
        style="color: var(--theme-muted); opacity: 0.6;"
        onmouseover="this.style.opacity='1'"
        onmouseout="this.style.opacity='0.6'"
      >GitHub ↗</a>
      <a href="https://linkedin.com" target="_blank"
        class="text-sm font-mono transition-colors"
        style="color: var(--theme-muted); opacity: 0.6;"
        onmouseover="this.style.opacity='1'"
        onmouseout="this.style.opacity='0.6'"
      >LinkedIn ↗</a>
    </div>
  </div>
</section>

<style>
  @keyframes fade-in  { from { opacity: 0; } to { opacity: 1; } }
  @keyframes slide-up { from { opacity: 0; transform: translateY(24px); } to { opacity: 1; transform: translateY(0); } }
</style>