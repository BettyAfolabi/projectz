---
// Hero.astro
---

<section class="relative mx-auto max-w-7xl px-6 pt-24 md:pt-32 pb-20 md:pb-24 reveal-section">

  <!-- Label -->
  <div class="flex items-center gap-3 mb-6 md:mb-8 reveal-item">
    <span class="h-px w-8 md:w-12 bg-[var(--theme-accent)] opacity-60" />
    <span class="text-xs font-mono tracking-[0.2em] uppercase text-[var(--theme-accent)] opacity-80">
      Frontend Engineer
    </span>
  </div>

  <!-- Name -->
  <h1
    class="reveal-item text-[clamp(2.8rem,10vw,8rem)] font-black leading-[0.9] tracking-tighter"
    style="font-family:'Georgia',serif; letter-spacing:-0.04em; color:var(--theme-text);"
  >
    Elizabeth<br />
    <span
      class="bg-gradient-to-br from-[var(--theme-accent)] to-[var(--theme-accent-hover)] bg-clip-text text-transparent"
    >
      Afolabi
    </span>
  </h1>

  <!-- Tagline -->
  <p
    class="mt-6 md:mt-7 max-w-xl text-base md:text-lg leading-relaxed reveal-item"
    style="font-family:'Georgia',serif; color:var(--theme-muted);"
  >
    I build interfaces that feel inevitable: fast, accessible, and obsessively
    detailed. Currently available for freelance and full-time roles.
  </p>

  <!-- CTAs -->
  <div class="reveal-item mt-8 md:mt-9 flex flex-wrap items-center gap-3">

    <!-- Primary CTA -->
   <a
      href="mailto:betty4web@gmail.com"
      class="
        group inline-flex items-center gap-2
        px-5 py-2.5 rounded-full
        text-sm font-semibold

        bg-[var(--theme-accent)]
        text-[var(--theme-bg)]

        hover:bg-[var(--theme-accent-hover)]
        transition-all duration-200
      "
    >
      Get in touch
      <span class="transition-transform group-hover:translate-x-0.5">→</span>
    </a>

    <!-- Secondary CTA -->
    <a
      href="/cv.pdf"
      target="_blank"
      class="flex items-center gap-2 px-5 py-2.5 rounded-full text-sm font-medium transition-all duration-200"
      style="border:1px solid var(--theme-border); color:var(--theme-muted);"
      onmouseenter="this.style.borderColor='var(--theme-accent)'; this.style.color='var(--theme-text)'"
      onmouseleave="this.style.borderColor='var(--theme-border)'; this.style.color='var(--theme-muted)'"
    >
      Download CV
    </a>

    <!-- Socials (de-emphasized) -->
    <div class="flex items-center gap-4 ml-2">
      <a
        href="https://github.com/BettyAfolabi"
        target="_blank"
        class="text-sm font-mono transition-opacity"
        style="color:var(--theme-muted); opacity:0.5;"
        onmouseenter="this.style.opacity='1'"
        onmouseleave="this.style.opacity='0.5'"
      >
        GitHub ↗
      </a>

      <a
        href="https://www.linkedin.com/in/elizabethafolabib"
        target="_blank"
        class="text-sm font-mono transition-opacity"
        style="color:var(--theme-muted); opacity:0.5;"
        onmouseenter="this.style.opacity='1'"
        onmouseleave="this.style.opacity='0.5'"
      >
        LinkedIn ↗
      </a>
    </div>

  </div>
</section>