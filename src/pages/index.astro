---
import CommandPalette from '../components/islands/CommandPalette';
import type { CollectionEntry } from 'astro:content';
import { getCollection } from 'astro:content';

import BentoGrid from '../components/layout/BentoGrid.astro';
import ProjectCard from '../components/ui/ProjectCard.astro';
import '../styles/global.css';

const projects: CollectionEntry<'projects'>[] =
  await getCollection('projects');

const sorted = [...projects].sort(
  (a, b) => Number(b.data.featured) - Number(a.data.featured)
);
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Project Zero</title>
  </head>

  <body>
    <main class="mx-auto max-w-7xl px-6 py-16">
      <h1 class="mb-10 text-4xl font-bold tracking-tight">
        Selected Work
      </h1>

      <BentoGrid>
        {sorted.map((project) => (
          <ProjectCard project={project} />
        ))}
      </BentoGrid>
    </main>

    <CommandPalette
      client:load
      items={sorted.map((project) => ({
        label: project.data.title,
        href: `/projects/${project.slug}`,
      }))}
    />
  </body>
</html>
