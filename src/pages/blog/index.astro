---
import BaseLayout from '../../components/layout/BaseLayout.astro';
import { getMediumPosts, type MediumPost } from '../../lib/medium';

let posts: MediumPost[] = [];

try {
  posts = await getMediumPosts(20);
} catch (e) {
  console.warn('Medium fetch failed:', e);
}
---

<BaseLayout>
  <div class="mx-auto max-w-7xl px-6 pt-10 pb-32">

    <a href="/" class="inline-flex items-center gap-2 text-sm font-mono mb-10 group transition-colors"
      style="color:var(--theme-muted);"
      onmouseover="this.style.color='var(--theme-text)'"
      onmouseout="this.style.color='var(--theme-muted)'">
      <span class="group-hover:-translate-x-0.5 transition-transform inline-block">←</span>
      Back home
    </a>

    <div class="mb-12">
      <p class="text-xs font-mono tracking-[0.2em] uppercase mb-3"
        style="color:var(--theme-accent);opacity:0.8;">Writing</p>
      <h1 class="text-4xl sm:text-5xl font-black tracking-tighter mb-4"
        style="font-family:'Georgia',serif;color:var(--theme-text);">
        What I'm writing about
      </h1>
      <p class="text-base max-w-xl leading-relaxed" style="color:var(--theme-muted);">
        Documenting my tech journey — frontend deep-dives, lessons learned, and things I find interesting.
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {posts.length > 0 ? (
        posts.map((post) => (
          <a
            href={post.link}
            target="_blank"
            rel="noopener noreferrer"
            class="flex flex-col rounded-2xl overflow-hidden transition-all"
            style="border:1px solid var(--theme-border); background:var(--theme-surface);"
          >
            <div class="aspect-video overflow-hidden">
              <img
                src={post.thumbnail}
                alt={post.title}
                class="w-full h-full object-cover"
              />
            </div>

            <div class="p-5 flex flex-col gap-2">
              <span class="text-xs font-mono opacity-50"
                style="color:var(--theme-muted);">
                {new Date(post.pubDate).toLocaleDateString('en-GB',{
                  day:'numeric',month:'short',year:'numeric'
                })}
              </span>

              <h2 class="font-semibold" style="color:var(--theme-text);">
                {post.title}
              </h2>

              <p class="text-sm" style="color:var(--theme-muted);">
                {post.description}
              </p>

              <span class="text-xs font-mono mt-2"
                style="color:var(--theme-accent);">
                Read on Medium ↗
              </span>
            </div>
          </a>
        ))
      ) : (
        <div class="col-span-full text-center py-20">
          <p class="text-sm font-mono" style="color:var(--theme-muted);">
            Couldn’t load posts at build time.
          </p>
        </div>
      )}
    </div>
  </div>
</BaseLayout>

<style>
  @keyframes shimmer {
    0%   { background-position: -400px 0; }
    100% { background-position:  400px 0; }
  }
  .skeleton-shimmer {
    background: linear-gradient(
      90deg,
      var(--theme-border) 25%,
      color-mix(in srgb, var(--theme-border) 60%, var(--theme-surface)) 50%,
      var(--theme-border) 75%
    );
    background-size: 800px 100%;
    animation: shimmer 1.6s ease-in-out infinite;
  }
</style>